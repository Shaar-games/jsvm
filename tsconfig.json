{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "bytecode/**/*.ts",
    "compiler/**/*.ts",
    "vm/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "external",
    "node_modules",
    "test",
    "vendor"
  ]
}
